  <main class="card">
    <section class="hero">
      <div class="eyebrow">Activation Tool</div>
      <h1>NBA经理激活碼計算器</h1>
      <p class="subtitle">輸入設備碼後，會依照你提供的小程序設備碼計算激活碼。</p>
    </section>

    <section class="content">
      <label for="deviceCode">設備碼</label>
      <div class="input-wrap">
        <input id="deviceCode" type="text" inputmode="numeric" autocomplete="off" placeholder="例如：26601986" maxlength="32">
      </div>

      <div class="actions">
        <button class="primary" id="calcBtn">計算激活碼</button>
        <button class="secondary" id="fillBtn">載入範例</button>
        <button class="secondary" id="clearBtn">清空</button>
      </div>

      <div class="result">
        <div class="result-title">激活碼</div>
        <div class="result-value" id="resultValue">------</div>
      </div>

      <div class="error" id="errorText"></div>
      <div class="hint">已知範例：<code>26601986 -> 115117</code></div>
