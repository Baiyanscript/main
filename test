      0x391c0cb3, 0x4ed8aa4a, 0x5b9cca4f, 0x682e6ff3, 0x748f82ee, 0x78a5636f,
      0x84c87814, 0x8cc70208, 0x90befffa, 0xa4506ceb, 0xbef9a3f7, 0xc67178f2
    ];

    function rotr(value, bits) {
      return value >>> bits | value << (32 - bits);
    }

    function encodeMessage(message) {
      const bytes = [];
      for (let i = 0; i < message.length; i += 1) {
        bytes.push(message.charCodeAt(i));
      }
      return bytes;
    }

    function toBytes(value) {
      return [value >> 24 & 255, value >> 16 & 255, value >> 8 & 255, value & 255];
    }

    function toHex(words) {
      let hex = '';
      for (let i = 0; i < words.length; i += 1) {
        hex += ('00000000' + words[i].toString(16)).slice(-8);
      }
      return hex;
    }

    function appSha256(message) {
      const hashState = [
        0x6a09e667, 0xbb67ae85, 0x3c6ef372, 0xa54ff53a,
        0x510e527f, 0x9b05688c, 0x1f83d9ab, 0x5be0cd19
      ];

      let buffer = encodeMessage(message);
      const length = buffer.length;

      buffer.push(128);
      while (buffer.length % 64 !== 56) {
        buffer.push(0);
      }
      buffer = buffer.concat(toBytes(8 * length));

      for (let offset = 0; offset < buffer.length; offset += 64) {
        const chunk = buffer.slice(offset, offset + 64);
        const words = Array(64);

        for (let i = 0; i < 16; i += 1) {
          words[i] = chunk[4 * i] << 24 | chunk[4 * i + 1] << 16 | chunk[4 * i + 2] << 8 | chunk[4 * i + 3];
