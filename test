        for (let i = 16; i < 64; i += 1) {
          const s0 = rotr(words[i - 15], 7) ^ rotr(words[i - 15], 18) ^ words[i - 15] >>> 3;
          const s1 = rotr(words[i - 2], 17) ^ rotr(words[i - 2], 19) ^ words[i - 2] >>> 10;
          words[i] = words[i - 16] + s0 + words[i - 7] + s1 >>> 0;
        }

        let a = hashState[0];
        let b = hashState[1];
        let c = hashState[2];
        let d = hashState[3];
        let e = hashState[4];
        let f = hashState[5];
        let g = hashState[6];
        let h = hashState[7];

        for (let i = 0; i < 64; i += 1) {
          const t1 = h + (rotr(e, 6) ^ rotr(e, 11) ^ rotr(e, 25)) + (e & f ^ ~e & g) + K[i] + words[i] >>> 0;
          const t2 = (rotr(a, 2) ^ rotr(a, 13) ^ rotr(a, 22)) + (a & b ^ a & c ^ b & c) >>> 0;

          h = g;
          g = f;
          f = e;
          e = d + t1 >>> 0;
          d = c;
          c = b;
          b = a;
          a = t1 + t2 >>> 0;
        }

        hashState[0] = hashState[0] + a >>> 0;
        hashState[1] = hashState[1] + b >>> 0;
        hashState[2] = hashState[2] + c >>> 0;
        hashState[3] = hashState[3] + d >>> 0;
        hashState[4] = hashState[4] + e >>> 0;
        hashState[5] = hashState[5] + f >>> 0;
        hashState[6] = hashState[6] + g >>> 0;
        hashState[7] = hashState[7] + h >>> 0;
      }

      return toHex(hashState);
    }

    function convertToOddNumbers(hexText) {
      let output = '';
      for (let i = 0; i < hexText.length; i += 1) {
        let value = parseInt(hexText[i], 16);
        if (value % 2 === 0) {
          value += 1;
        }
        output += value.toString();
      }
      return output.slice(0, 6);
    }

    function getActivationCode(deviceCode) {
      const source = deviceCode + '/data/app/watchface/market/12345678900987654321//_lua/app/';
      const lastSix = appSha256(source).slice(-6);
      return convertToOddNumbers(lastSix);
    }

    function setError(message) {
      errorText.textContent = message;
      errorText.style.display = message ? 'block' : 'none';
    }

    function calculate() {
      const deviceCode = deviceInput.value.trim();

      if (!deviceCode) {
        resultValue.textContent = '------';
        setError('請先輸入設備碼。');
        return;
      }

      if (!/^\d+$/.test(deviceCode)) {
        resultValue.textContent = '------';
        setError('設備碼只能輸入數字。');
        return;
      }

      setError('');
      resultValue.textContent = getActivationCode(deviceCode);
    }

    calcBtn.addEventListener('click', calculate);
    fillBtn.addEventListener('click', () => {
      deviceInput.value = '26601986';
      calculate();
    });
    clearBtn.addEventListener('click', () => {
      deviceInput.value = '';
      resultValue.textContent = '------';
      setError('');
      deviceInput.focus();
    });
    deviceInput.addEventListener('input', () => {
      deviceInput.value = deviceInput.value.replace(/\D+/g, '');
      if (deviceInput.value) {
        calculate();
      } else {
        resultValue.textContent = '------';
        setError('');
      }
    });
    deviceInput.addEventListener('keydown', (event) => {
      if (event.key === 'Enter') {
        calculate();
      }
    });
  </script>
